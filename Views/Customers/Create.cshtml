@model OrderFlowMVC.Models.CreateCustomerRequest
@{ Layout = "_Layout"; ViewData["Title"] = "New Customer"; }

<div class="page-header">
    <div class="page-header-left">
        <h1>New Customer</h1>
        <p>Add a new customer to the system</p>
    </div>
    <a asp-action="Index" class="btn btn-secondary">← Back</a>
</div>

<div class="form-card">
    <form asp-action="Create" method="post">
        @Html.AntiForgeryToken()
        <div class="form-grid form-grid-2">
            <div class="form-group">
                <label class="form-label">First Name</label>
                <input asp-for="FirstName" class="form-control" placeholder="Maria" />
                <span asp-validation-for="FirstName" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label class="form-label">Last Name</label>
                <input asp-for="LastName" class="form-control" placeholder="Santos" />
                <span asp-validation-for="LastName" class="field-validation-error"></span>
            </div>
            <div class="form-group col-2">
                <label class="form-label">Email Address</label>
                <input asp-for="Email" type="email" class="form-control" placeholder="maria@email.com" />
                <span asp-validation-for="Email" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label class="form-label">Phone</label>
                <input asp-for="Phone" class="form-control" placeholder="09171234567" />
                <span asp-validation-for="Phone" class="field-validation-error"></span>
            </div>
            <div class="form-group">
                <label class="form-label">Address</label>
                <input asp-for="Address" class="form-control" placeholder="Makati City" />
                <span asp-validation-for="Address" class="field-validation-error"></span>
            </div>
        </div>
        <div class="form-actions" style="margin-top:20px;">
            <button type="submit" class="btn btn-primary">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg>
                Create Customer
            </button>
            <a asp-action="Index" class="btn btn-secondary">Cancel</a>
        </div>
    </form>
</div>
