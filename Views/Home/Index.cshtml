@model OrderFlowMVC.ViewModels.DashboardViewModel
@{ Layout = "_Layout"; ViewData["Title"] = "Dashboard"; }

<div class="stats-grid">
    <div class="stat-card">
        <div class="stat-icon green">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
        </div>
        <div class="stat-value">@Model.TotalCustomers</div>
        <div class="stat-label">Customers</div>
        <div class="stat-sub">@Model.ActiveCustomers active</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon amber">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
        </div>
        <div class="stat-value">@Model.TotalProducts</div>
        <div class="stat-label">Products</div>
        <div class="stat-sub">@Model.LowStockProducts low stock</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon blue">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
        </div>
        <div class="stat-value">@Model.TotalOrders</div>
        <div class="stat-label">Orders</div>
        <div class="stat-sub">@Model.PendingOrders pending</div>
    </div>
    <div class="stat-card">
        <div class="stat-icon red">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="12" y1="1" x2="12" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 000 7h5a3.5 3.5 0 010 7H6"/></svg>
        </div>
        <div class="stat-value" style="font-size:1.55rem;">₱@Model.TotalRevenue.ToString("N0")</div>
        <div class="stat-label">Revenue</div>
        <div class="stat-sub">From delivered orders</div>
    </div>
</div>

<div class="dash-grid">
    <div class="panel">
        <div class="panel-header">
            <span class="panel-title">Recent Orders</span>
            <a asp-controller="Orders" asp-action="Index" class="btn btn-secondary btn-sm">View all</a>
        </div>
        @if (!Model.RecentOrders.Any())
        {
            <div class="empty-state">
                <svg width="38" height="38" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/></svg>
                <p>No orders yet</p>
            </div>
        }
        else
        {
            <table class="data-table">
                <thead><tr><th>Order #</th><th>Customer</th><th>Amount</th><th>Status</th><th>Date</th></tr></thead>
                <tbody>
                @foreach (var o in Model.RecentOrders)
                {
                    <tr>
                        <td><a asp-controller="Orders" asp-action="Details" asp-route-id="@o.Id" style="color:var(--accent);text-decoration:none;font-weight:700;">#@o.Id</a></td>
                        <td><strong>@o.CustomerName</strong></td>
                        <td class="font-mono">₱@o.TotalAmount.ToString("N2")</td>
                        <td><span class="badge badge-@o.Status.ToLower()">@o.Status</span></td>
                        <td class="text-muted">@o.OrderDate.ToString("MMM d, yyyy")</td>
                    </tr>
                }
                </tbody>
            </table>
        }
    </div>

    <div class="panel">
        <div class="panel-header">
            <span class="panel-title">Top Products</span>
            <a asp-controller="Products" asp-action="Index" class="btn btn-secondary btn-sm">View all</a>
        </div>
        <div style="padding:8px;">
            @foreach (var p in Model.TopProducts)
            {
                <div style="display:flex;align-items:center;gap:11px;padding:10px;border-radius:7px;transition:background var(--t);" onmouseover="this.style.background='var(--bg-2)'" onmouseout="this.style.background='transparent'">
                    <div style="width:34px;height:34px;border-radius:8px;background:var(--accent-bg);display:flex;align-items:center;justify-content:center;flex-shrink:0;color:var(--accent);">
                        <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
                    </div>
                    <div style="flex:1;min-width:0;">
                        <div style="font-size:.85rem;font-weight:600;white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">@p.Name</div>
                        <div style="font-size:.73rem;color:var(--text-3);">@p.Category · @p.StockQuantity in stock</div>
                    </div>
                    <div style="font-family:'Fraunces',Georgia,serif;font-weight:700;font-size:.9rem;white-space:nowrap;color:var(--text);">₱@p.Price.ToString("N0")</div>
                </div>
            }
        </div>
    </div>
</div>
