<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] — OrderFlow</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght@0,9..144,400;0,9..144,600;0,9..144,700;1,9..144,400&family=Instrument+Sans:wght@400;500;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
@{
    var isLoggedIn = Context.Session.GetString("JwtToken") != null;
    var username   = Context.Session.GetString("Username") ?? "";
    var role       = Context.Session.GetString("Role") ?? "";
    var isAdmin    = role == "Admin";
    var path       = Context.Request.Path.Value ?? "";
    bool IsActive(string seg) => path.StartsWith(seg, StringComparison.OrdinalIgnoreCase);
}
@if (isLoggedIn)
{
<div class="app-shell">
    <aside class="sidebar" id="sidebar">
        <div class="sidebar-logo">
            <div class="logo-icon">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M3 9l9-7 9 7v11a2 2 0 01-2 2H5a2 2 0 01-2-2z"/><polyline points="9,22 9,12 15,12 15,22"/></svg>
            </div>
            <span class="logo-text">OrderFlow</span>
        </div>
        <nav class="sidebar-nav">
            <div class="nav-section-label">Overview</div>
            <a asp-controller="Home" asp-action="Index" class="nav-item @(path == "/" || IsActive("/Home") ? "active" : "")">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="3" width="7" height="7" rx="1"/><rect x="14" y="3" width="7" height="7" rx="1"/><rect x="3" y="14" width="7" height="7" rx="1"/><rect x="14" y="14" width="7" height="7" rx="1"/></svg>
                Dashboard
            </a>
            <div class="nav-section-label">Management</div>
            <a asp-controller="Customers" asp-action="Index" class="nav-item @(IsActive("/Customers") ? "active" : "")">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M17 21v-2a4 4 0 00-4-4H5a4 4 0 00-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 00-3-3.87"/><path d="M16 3.13a4 4 0 010 7.75"/></svg>
                Customers
            </a>
            <a asp-controller="Products" asp-action="Index" class="nav-item @(IsActive("/Products") ? "active" : "")">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M21 16V8a2 2 0 00-1-1.73l-7-4a2 2 0 00-2 0l-7 4A2 2 0 003 8v8a2 2 0 001 1.73l7 4a2 2 0 002 0l7-4A2 2 0 0021 16z"/></svg>
                Products
            </a>
            <a asp-controller="Orders" asp-action="Index" class="nav-item @(IsActive("/Orders") ? "active" : "")">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 2L3 6v14a2 2 0 002 2h14a2 2 0 002-2V6l-3-4z"/><line x1="3" y1="6" x2="21" y2="6"/><path d="M16 10a4 4 0 01-8 0"/></svg>
                Orders
            </a>
        </nav>
        <div class="sidebar-footer">
            <div class="user-card">
                <div class="user-avatar">@(username.Length > 0 ? username[0].ToString().ToUpper() : "U")</div>
                <div class="user-info">
                    <div class="user-name">@username</div>
                    <div class="user-role @(isAdmin ? "role-admin" : "role-user")">@role</div>
                </div>
            </div>
            <a asp-controller="Auth" asp-action="Logout" class="logout-btn" title="Sign out">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 21H5a2 2 0 01-2-2V5a2 2 0 012-2h4"/><polyline points="16,17 21,12 16,7"/><line x1="21" y1="12" x2="9" y2="12"/></svg>
            </a>
        </div>
    </aside>
    <main class="main-content">
        <header class="top-bar">
            <button class="menu-toggle" onclick="document.getElementById('sidebar').classList.toggle('sidebar-open')">
                <svg width="19" height="19" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
            </button>
            <div class="page-title">@(ViewData["Title"] ?? "Dashboard")</div>
            <div class="top-bar-right">
                <div class="status-pill">
                    <span class="status-dot"></span>Live
                </div>
            </div>
        </header>
        @if (TempData["Success"] != null) {
        <div class="toast toast-success show" id="toastEl">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20,6 9,17 4,12"/></svg>
            <span>@TempData["Success"]</span>
        </div>
        }
        @if (TempData["Error"] != null) {
        <div class="toast toast-error show" id="toastEl">
            <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>
            <span>@TempData["Error"]</span>
        </div>
        }
        <div class="content-body">
            @RenderBody()
        </div>
    </main>
</div>
}
else
{
<div class="auth-shell">@RenderBody()</div>
}
<script>
window.addEventListener('DOMContentLoaded',()=>{
    const t=document.getElementById('toastEl');
    if(t){setTimeout(()=>{t.style.opacity='0';t.style.transform='translateY(-10px)';},4000);}
});
</script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
